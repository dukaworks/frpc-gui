# ============================================================
# Frpc-GUI — Native Local Mode Configuration
# ============================================================
# Copy this file to .env.local and adjust values as needed.
#
# When FRPC_GUI_MODE=local:
#   - No SSH login required
#   - Frpc-GUI discovers and controls frpc on the LOCAL machine
#   - Supports Docker containers, systemd services, and raw processes
#   - Service start/stop/restart and log fetching are fully functional
# ============================================================

# Enable Native Local Mode
FRPC_GUI_MODE=local

# Path to the local frpc configuration file
# Examples:
#   - /etc/frp/frpc.toml       (Linux default)
#   - /etc/frpc.toml
#   - C:\frp\frpc.toml         (Windows path)
FRPC_CONFIG_PATH=/etc/frp/frpc.toml

# Frpc built-in webServer API (optional, for reload/status)
# Only needed if frpc was started with webServer config
FRPC_WEB_SERVER_ADDR=127.0.0.1
FRPC_WEB_SERVER_PORT=7400
