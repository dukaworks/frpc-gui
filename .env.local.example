# Frpc-GUI Local Mode Configuration Example
# Copy this file to .env.local and adjust the values as needed

# Enable local mode (set to 'local' to enable)
FRPC_GUI_MODE=local

# Path to your local frpc configuration file
# This is used when FRPC_GUI_MODE=local
FRPC_CONFIG_PATH=/etc/frp/frpc.toml

# Frpc web server configuration (for reload/status API)
# This is used when FRPC_GUI_MODE=local
FRPC_WEB_SERVER_ADDR=127.0.0.1
FRPC_WEB_SERVER_PORT=7400